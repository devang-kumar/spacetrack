<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | SpaceTrack</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-space-dark text-white font-sans flex items-center justify-center min-h-screen p-4">
    <div class="max-w-md w-full">
        <div class="text-center mb-12">
            <a href="/" class="inline-block mb-8">
                <span class="text-4xl font-bold font-space tracking-tight">SPACE<span class="text-blue-500">TRACK</span></span>
            </a>
            <h1 class="text-3xl font-bold mb-4">Welcome Back, <span class="text-blue-500">Explorer</span></h1>
            <p class="text-gray-400">Login to save missions and get notifications.</p>
        </div>

        <div class="bg-black/40 backdrop-blur-xl border border-white/10 p-10 rounded-3xl shadow-2xl">
            <form action="/auth/login" method="POST" class="space-y-6">
                <div>
                    <label class="block text-sm text-gray-400 mb-2 font-medium">Username</label>
                    <input type="text" name="username" placeholder="Enter username" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 focus:border-blue-500 outline-none transition-colors" required>
                </div>
                <div>
                    <label class="block text-sm text-gray-400 mb-2 font-medium">Password</label>
                    <input type="password" name="password" placeholder="Enter password" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 focus:border-blue-500 outline-none transition-colors" required>
                </div>
                <button type="submit" class="w-full bg-blue-600 px-8 py-4 rounded-xl hover:bg-blue-700 transition-all transform hover:scale-[1.02] font-bold shadow-lg shadow-blue-500/20">Login</button>
            </form>
            <div class="mt-8 text-center">
                <p class="text-sm text-gray-500">Don't have an account? <a href="#" class="text-blue-400 hover:text-blue-300">Sign Up</a></p>
            </div>
        </div>
    </div>
</body>
</html>
