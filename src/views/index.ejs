<!-- Hero Section -->
<section class="relative h-[50vh] sm:h-[60vh] flex items-center justify-center overflow-hidden rounded-2xl sm:rounded-3xl mb-8 sm:mb-12">
    <div class="absolute inset-0 bg-gradient-to-r from-blue-900/40 to-black/60 z-10"></div>
    <video autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover">
        <source src="https://www.spacex.com/media/mission_starship_flight_3.mp4" type="video/mp4">
    </video>
    <div class="relative z-20 text-center px-4">
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold font-space mb-4 sm:mb-6 tracking-tight animate-fade-in">
            EXPLORE THE <span class="text-blue-500">COSMOS</span>
        </h1>
        <p class="text-base sm:text-xl md:text-2xl text-gray-300 mb-6 sm:mb-8 max-w-2xl mx-auto">
            Real-time tracking of global space missions, launch statistics, and orbital data.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
            <a href="#upcoming" class="bg-blue-600 px-6 sm:px-8 py-3 rounded-xl hover:bg-blue-700 transition-all font-semibold text-sm sm:text-base">Upcoming Missions</a>
            <a href="/analytics" class="bg-white/10 backdrop-blur-md border border-white/20 px-6 sm:px-8 py-3 rounded-xl hover:bg-white/20 transition-all font-semibold text-sm sm:text-base">View Analytics</a>
        </div>
    </div>
</section>

<!-- Search and Filter Bar -->
<section class="mb-8 sm:mb-12">
    <%- include('partials/data-timeline', { sources: ['ll2', 'nasa'], pageNote: 'Upcoming + recent global missions' }) %>
    <form action="/launches/search" method="GET" class="bg-black/40 backdrop-blur-xl border border-white/10 p-4 sm:p-6 rounded-2xl flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 items-stretch sm:items-end">
        <div class="flex-1 min-w-0">
            <label class="block text-sm text-gray-400 mb-2 font-medium">Search Missions</label>
            <input type="text" name="query" placeholder="E.g. Starlink, Falcon 9..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:border-blue-500 outline-none transition-colors text-sm">
        </div>
        <div class="sm:min-w-[140px]">
            <label class="block text-sm text-gray-400 mb-2 font-medium">Status</label>
            <select name="status" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:border-blue-500 outline-none transition-colors appearance-none text-sm">
                <option value="">All</option>
                <option value="success">Success</option>
                <option value="failure">Failure</option>
                <option value="upcoming">Upcoming</option>
            </select>
        </div>
        <button type="submit" class="bg-blue-600 px-6 py-3 rounded-xl hover:bg-blue-700 transition-colors font-semibold text-sm">Search</button>
    </form>
</section>

<!-- NASA APOD Section -->
<% if (apod) { %>
<section class="mb-10 sm:mb-16">
    <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl sm:rounded-3xl overflow-hidden">
        <div class="flex flex-col lg:flex-row">
            <div class="w-full lg:w-1/2 h-56 sm:h-72 lg:h-auto overflow-hidden">
                <img src="<%= apod.url %>" alt="<%= apod.title %>" class="w-full h-full object-cover">
            </div>
            <div class="w-full lg:w-1/2 p-5 sm:p-8 lg:p-12">
                <div class="flex items-center gap-2 mb-3">
                    <span class="bg-red-600 text-[10px] font-bold px-2 py-0.5 rounded">NASA</span>
                    <span class="text-xs text-gray-400 font-medium">Astronomy Picture of the Day</span>
                </div>
                <h2 class="text-xl sm:text-2xl lg:text-3xl font-bold font-space mb-3"><%= apod.title %></h2>
                <p class="text-gray-400 leading-relaxed line-clamp-4 mb-4 text-sm sm:text-base"><%= apod.explanation %></p>
                <p class="text-xs text-gray-500 italic">© <%= apod.copyright || 'Public Domain' %></p>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- Upcoming Missions -->
<section id="upcoming" class="mb-10 sm:mb-16">
    <div class="flex justify-between items-center mb-5 sm:mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold font-space">Upcoming <span class="text-blue-500">Missions</span></h2>
        <a href="/launches/search?status=upcoming" class="text-blue-400 hover:text-blue-300 text-sm whitespace-nowrap">View All →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
        <% upcoming.slice(0, 6).forEach(launch => { %>
            <div class="group bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl sm:rounded-3xl overflow-hidden hover:border-blue-500/50 transition-all duration-300">
                <div class="relative h-40 sm:h-48 bg-gradient-to-br from-blue-900/20 to-black overflow-hidden">
                    <% if (launch.image) { %>
                        <img src="<%= launch.image %>" alt="<%= launch.name %>" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    <% } else { %>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <svg class="w-16 h-16 text-white/10" fill="currentColor" viewBox="0 0 20 20"><path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"></path><path d="M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z"></path></svg>
                        </div>
                    <% } %>
                    <div class="absolute top-3 left-3">
                        <span class="bg-blue-600/90 text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-wider max-w-[160px] truncate block">
                            <%= launch.launch_service_provider ? launch.launch_service_provider.name : 'Unknown' %>
                        </span>
                    </div>
                </div>
                <div class="p-4 sm:p-6">
                    <h3 class="text-base sm:text-lg font-bold mb-2 truncate"><%= launch.name %></h3>
                    <p class="text-gray-400 text-xs sm:text-sm mb-4 line-clamp-2"><%= launch.mission ? launch.mission.description : 'Global mission tracking in progress.' %></p>
                    <div class="flex justify-between items-center gap-2">
                        <div class="text-xs text-blue-400 font-mono countdown truncate" data-date="<%= launch.window_start || launch.net %>">
                            Calculating...
                        </div>
                        <a href="/launches/<%= launch.id %>" class="flex-shrink-0 bg-white/5 hover:bg-blue-600 px-3 py-1.5 rounded-lg text-xs transition-colors">Details</a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</section>

<!-- Past Launches -->
<section class="mb-10 sm:mb-16">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-5 sm:mb-8 gap-3">
        <h2 class="text-2xl sm:text-3xl font-bold font-space">Recent <span class="text-gray-500">Missions</span></h2>
        <div class="flex items-center gap-1.5 bg-white/5 p-1 rounded-xl border border-white/10 self-start sm:self-auto">
            <button class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all bg-blue-600 text-white" data-filter="all">ALL</button>
            <button class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all text-gray-400 hover:bg-white/5" data-filter="success">SUCCESS</button>
            <button class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all text-gray-400 hover:bg-white/5" data-filter="failure">FAILED</button>
        </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6" id="past-missions-grid">
        <% past.forEach(launch => { %>
            <% const status = launch.status ? launch.status.abbrev : 'UNKNOWN' %>
            <div class="mission-card bg-black/40 backdrop-blur-sm border border-white/5 rounded-2xl overflow-hidden hover:bg-white/5 transition-all" data-status="<%= status === 'Success' ? 'success' : 'failure' %>">
                <div class="p-4 sm:p-5">
                    <div class="flex items-center justify-between mb-3">
                        <span class="text-[10px] font-bold uppercase tracking-widest text-gray-500"><%= new Date(launch.net).toLocaleDateString() %></span>
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold <%= status === 'Success' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' %>">
                            <%= status.toUpperCase() %>
                        </span>
                    </div>
                    <h4 class="font-bold mb-1.5 truncate text-sm"><%= launch.name %></h4>
                    <p class="text-[10px] text-blue-400 font-bold mb-4 uppercase tracking-tighter truncate"><%= launch.launch_service_provider.name %></p>
                    <a href="/launches/<%= launch.id %>" class="block text-center bg-white/5 hover:bg-blue-600/20 py-2 rounded-lg text-xs transition-colors border border-white/5">View Mission</a>
                </div>
            </div>
        <% }) %>
    </div>
</section>
