<% const _tl = dataTimeline || {};
const _sources = (typeof sources !== 'undefined' ? sources : Object.keys(_tl));
const _note = (typeof pageNote !== 'undefined' ? pageNote : null);
const _colorMap = {
  blue:   'text-blue-400 border-blue-500/30 bg-blue-500/10',
  purple: 'text-purple-400 border-purple-500/30 bg-purple-500/10',
  red:    'text-red-400 border-red-500/30 bg-red-500/10',
  green:  'text-green-400 border-green-500/30 bg-green-500/10',
  orange: 'text-orange-400 border-orange-500/30 bg-orange-500/10'
};
%>
<div class="flex flex-wrap items-center gap-3 px-4 py-2.5 mb-5 bg-white/[0.03] border border-white/[0.07] rounded-2xl text-xs">
    <span class="text-gray-600 font-bold uppercase tracking-widest flex-shrink-0">Data sources</span>
    <% _sources.forEach(function(key) {
        var src = _tl[key];
        if (!src) return;
        var cls = _colorMap[src.color] || 'text-gray-400 border-white/10 bg-white/5';
    %>
    <span class="group relative flex items-center gap-1.5 px-2.5 py-1 rounded-lg border <%= cls %> cursor-default">
        <span class="w-1.5 h-1.5 rounded-full bg-current opacity-70 flex-shrink-0"></span>
        <span class="font-bold"><%= src.label %></span>
        <% if (src.from) { %><span class="opacity-60 ml-1"><%= src.from %> &ndash; <%= src.to %></span><% } %>
        <span class="pointer-events-none absolute bottom-full left-0 mb-2 w-48 bg-black/95 border border-white/10 text-gray-300 text-[10px] px-3 py-2 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity z-50 leading-relaxed">
            <%= src.note %>
        </span>
    </span>
    <% }); %>
    <% if (_note) { %>
    <span class="ml-auto text-gray-500 italic hidden sm:inline"><%= _note %></span>
    <% } %>
</div>
