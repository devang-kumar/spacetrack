<div class="py-8 sm:py-12">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-5 sm:mb-6">
        <h1 class="text-3xl sm:text-4xl font-bold font-space">Search <span class="text-blue-500">Results</span></h1>
        <p class="text-gray-400 text-sm">Found <%= results.length %> missions</p>
    </div>

    <%- include('partials/data-timeline', { sources: ['spacex'], pageNote: 'SpaceX launches only - all-time' }) %>

    <% if (results.length === 0) { %>
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 p-10 sm:p-20 rounded-2xl sm:rounded-3xl text-center">
            <svg class="w-14 h-14 sm:w-20 sm:h-20 text-gray-500 mx-auto mb-4 sm:mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <h2 class="text-xl sm:text-2xl font-bold mb-3">No Missions Found</h2>
            <p class="text-gray-400 mb-6 text-sm sm:text-base">Try adjusting your search filters or keywords.</p>
            <a href="/" class="bg-blue-600 px-6 py-3 rounded-xl hover:bg-blue-700 transition-colors text-sm">Return to Home</a>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
            <% results.forEach(launch => { %>
                <div class="group bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl sm:rounded-3xl overflow-hidden hover:border-blue-500/50 transition-all duration-300">
                    <div class="relative h-40 sm:h-48 bg-gradient-to-br from-blue-900/20 to-black overflow-hidden">
                        <% if (launch.links && launch.links.patch && launch.links.patch.large) { %>
                            <img src="<%= launch.links.patch.large %>" alt="<%= launch.name %>" class="absolute inset-0 w-full h-full object-contain p-6 sm:p-8 group-hover:scale-110 transition-transform duration-500">
                        <% } else { %>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <svg class="w-16 h-16 text-white/10" fill="currentColor" viewBox="0 0 20 20"><path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"></path><path d="M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z"></path></svg>
                            </div>
                        <% } %>
                    </div>
                    <div class="p-4 sm:p-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-gray-500"><%= new Date(launch.date_utc).toLocaleDateString() %></span>
                            <span class="px-2 py-0.5 rounded text-[10px] font-bold <%= launch.success ? 'bg-green-500/20 text-green-400' : launch.upcoming ? 'bg-blue-500/20 text-blue-400' : 'bg-red-500/20 text-red-400' %>">
                                <%= launch.upcoming ? 'UPCOMING' : launch.success ? 'SUCCESS' : 'FAILED' %>
                            </span>
                        </div>
                        <h3 class="text-base sm:text-lg font-bold mb-2 truncate"><%= launch.name %></h3>
                        <p class="text-xs text-gray-400 mb-4 truncate">Rocket: <%= launch.rocket.name %></p>
                        <a href="/launches/<%= launch.id %>" class="block text-center bg-white/5 hover:bg-blue-600 py-2.5 rounded-xl text-xs sm:text-sm font-semibold transition-colors border border-white/5">Details</a>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>
